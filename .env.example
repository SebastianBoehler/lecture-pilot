# Provider keys are optional until you run real tutor turns.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Default text model for the ADK/LiteLLM-backed agent runtime.
LECTUREPILOT_MODEL=openrouter/z-ai/glm-5.1

# Local development workspace root. Production should use object storage.
LECTUREPILOT_WORKSPACE_ROOT=./storage/workspaces

