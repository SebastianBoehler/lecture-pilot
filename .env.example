# Provider keys are required by tutor turns. The backend calls the selected
# provider through LiteLLM.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Required by the production Compose stack. Use a real DNS hostname and a
# URL-safe password generated with `python3 -c 'import secrets; print(secrets.token_urlsafe(32))'`.
LECTUREPILOT_DOMAIN=
LECTUREPILOT_POSTGRES_PASSWORD=

# Public, non-secret source revision. Compose bakes it into the API image and
# preflight verifies the running image matches it. /api/health reads the baked
# value, never a runtime override.
LECTUREPILOT_COMMIT_SHA=

# Local demo auth uses explicit dev headers. Compose overrides these with
# production, session auth, Secure cookies, SameSite=Lax, HSTS, and rate limits.
LECTUREPILOT_ENV=development
LECTUREPILOT_AUTH_MODE=dev
LECTUREPILOT_SESSION_TTL_MINUTES=480
LECTUREPILOT_SESSION_COOKIE_SECURE=false
LECTUREPILOT_SESSION_COOKIE_SAMESITE=lax
LECTUREPILOT_HSTS_ENABLED=false

# Generous request and abuse limits. Keep these in place even for pilots.
LECTUREPILOT_MAX_REQUEST_BYTES=629145600
LECTUREPILOT_RATE_LIMIT_ENABLED=true
LECTUREPILOT_RATE_LIMIT_LOGIN_PER_MINUTE=30
LECTUREPILOT_RATE_LIMIT_CHAT_PER_MINUTE=120
LECTUREPILOT_RATE_LIMIT_PAID_PER_MINUTE=60

# TeX-only slide previews require the isolated compiler container. The
# production Compose stack sets its internal URL automatically.
LECTUREPILOT_LATEX_COMPILER_URL=http://127.0.0.1:8081

# Default text model for the ADK/LiteLLM-backed agent runtime.
LECTUREPILOT_MODEL=openai/gpt-5.6-luna
LECTUREPILOT_ALLOWED_MODELS=openai/gpt-5.6-luna

# Optional real text-to-image generation for canvas infographics.
# Provider can be auto, gemini, openrouter, huggingface, or none.
LECTUREPILOT_IMAGE_PROVIDER=auto
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_ASPECT_RATIO=16:9
GEMINI_IMAGE_SIZE=1K
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_IMAGE_ASPECT_RATIO=16:9
OPENROUTER_IMAGE_SIZE=1K
HF_TOKEN=
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-dev
HUGGINGFACE_IMAGE_WIDTH=1280
HUGGINGFACE_IMAGE_HEIGHT=720

# Optional professor media discovery during course creation.
YOUTUBE_API_KEY=
YOUTUBE_PREFERRED_LANGUAGE=en
YOUTUBE_MIN_DURATION_SECONDS=90

# Optional backend observability for agent/tool/model traces. Use `logging` for
# metadata-only JSON spans, or `mlflow` with a self-hosted tracking server.
LECTUREPILOT_OBSERVABILITY=none
LECTUREPILOT_TRACE_CONTENT=metadata
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=lecturepilot-dev

VITE_API_BASE_URL=http://127.0.0.1:8000

# Local workspace root. Production Compose overrides this with the persisted
# /app/storage volume; an object-storage adapter is not implemented yet.
LECTUREPILOT_WORKSPACE_ROOT=.lecturepilot
LECTUREPILOT_COURSE_MATERIAL_ROOT=
