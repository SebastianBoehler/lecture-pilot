# Provider keys are required by tutor turns. The backend calls the selected
# provider through LiteLLM.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Default text model for the ADK/LiteLLM-backed agent runtime.
LECTUREPILOT_MODEL=gemini/gemini-3.1-flash-lite

# Optional real text-to-image generation for canvas infographics.
# Provider can be auto, gemini, openrouter, huggingface, or none.
LECTUREPILOT_IMAGE_PROVIDER=auto
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_ASPECT_RATIO=16:9
GEMINI_IMAGE_SIZE=1K
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_IMAGE_ASPECT_RATIO=16:9
OPENROUTER_IMAGE_SIZE=1K
HF_TOKEN=
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-dev
HUGGINGFACE_IMAGE_WIDTH=1280
HUGGINGFACE_IMAGE_HEIGHT=720

# Optional professor media discovery during course creation.
YOUTUBE_API_KEY=
YOUTUBE_PREFERRED_LANGUAGE=en
YOUTUBE_MIN_DURATION_SECONDS=90

# Optional backend observability for agent/tool/model traces.
# Set LECTUREPILOT_OBSERVABILITY=mlflow and MLFLOW_TRACKING_URI when a
# self-hosted MLflow tracking server is available.
LECTUREPILOT_OBSERVABILITY=none
LECTUREPILOT_TRACE_CONTENT=metadata
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=lecturepilot-dev

VITE_API_BASE_URL=http://127.0.0.1:8000

# Local development workspace root. Production should use object storage.
LECTUREPILOT_WORKSPACE_ROOT=.lecturepilot/workspaces
LECTUREPILOT_COURSE_MATERIAL_ROOT=
